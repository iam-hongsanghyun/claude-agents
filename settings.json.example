{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "[ -d .git ] && [ ! -f CLAUDE.md ] && cp ~/.claude/templates/CLAUDE.md CLAUDE.md 2>/dev/null; true",
            "statusMessage": "Init CLAUDE.md (git repos only)",
            "async": true
          }
        ]
      }
    ]
  }
}
